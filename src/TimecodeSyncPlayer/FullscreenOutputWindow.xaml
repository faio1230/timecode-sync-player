<Window x:Class="TimecodeSyncPlayer.FullscreenOutputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Title="Timecode Sync Player Fullscreen"
        AutomationProperties.AutomationId="FullscreenOutputWindow"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Black"
        Cursor="None"
        Focusable="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown"
        MouseEnter="Window_MouseEnter">
    <Grid Background="Black" UseLayoutRounding="True" SnapsToDevicePixels="True">
        <Image x:Name="FullscreenImage"
               Stretch="Uniform"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               UseLayoutRounding="True"
               SnapsToDevicePixels="True"
               RenderOptions.BitmapScalingMode="HighQuality"/>
    </Grid>
</Window>
